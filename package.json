{
  "name": "iq-wiki-word-brain",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "npm run check:html && npm run check:assets && npm run test:logic && npm run test:browser",
    "check:html": "html-validate index.html",
    "check:assets": "node scripts/check-assets.mjs",
    "test:logic": "node --test tests/game-logic.test.cjs",
    "test:browser": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "1.61.1",
    "html-validate": "9.7.1"
  }
}
